generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id
  username        String?
  phone           String    @unique
  phoneVerifiedAt DateTime?
  email           String?   @unique
  emailVerifiedAt DateTime?
  avatarUrl       String?
  sizeTop         String?
  sizeBottom      String?
  sizeShoes       String?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wardrobeItems WardrobeItem[]
  looks         Look[]
  likes         Like[]
  savedLooks    SavedLook[]
  comments      Comment[]
  following     Follow[]       @relation("following")
  followers     Follow[]       @relation("followers")
  phoneOtps     PhoneOtp[]
  usageEvents   UsageEvent[]
  entitlement   UserEntitlement?
}

model WardrobeItem {
  id           String   @id
  userId       String
  title        String
  category     String
  gender       String
  tags         String[]
  color        String?
  material     String?
  notes        String?
  sourceType   String   @default("own")
  price        Int?
  currency     String?
  storeId      String?
  storeName    String?
  brand        String?
  productUrl   String?
  affiliateUrl String?
  imageUrl     String?
  originalKey  String?
  cutoutKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Look {
  id              String    @id
  userId          String
  title           String
  itemIds         String[]
  sourceItems     Json?
  resultImageKey  String?
  isPublic        Boolean   @default(false)
  userDescription String?
  aiDescription   String?
  priceBuyNowRUB  Int       @default(0)
  buyLinks        String[]
  likesCount      Int       @default(0)
  savesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comments        Comment[]
  likes           Like[]
  savedBy         SavedLook[]
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id
  userId    String
  lookId    String
  createdAt DateTime @default(now())
  look      Look     @relation(fields: [lookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lookId])
  @@index([lookId])
}


model SavedLook {
  id        String   @id
  userId    String
  lookId    String
  createdAt DateTime @default(now())

  look      Look     @relation(fields: [lookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lookId])
  @@index([userId])
  @@index([lookId])
}

model Comment {
  id        String   @id
  userId    String
  lookId    String
  text      String
  createdAt DateTime @default(now())
  look      Look     @relation(fields: [lookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lookId])
}

model Follow {
  id          String   @id
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Clickout {
  id        String   @id
  userId    String?
  productId String?
  createdAt DateTime @default(now())
  meta      Json?
}

model PhoneOtp {
  id         String    @id
  userId     String?
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, createdAt])
  @@index([phone, expiresAt])
}


model CatalogProduct {
  id            String   @id
  merchant      String
  externalId    String

  title         String
  brand         String?
  category      String?
  gender        String?

  price         Float?
  oldPrice      Float?
  currency      String?

  sizesTop      String[] @default([])
  sizesBottom   String[] @default([])
  sizesShoes    String[] @default([])

  imageUrl      String?
  productUrl    String?
  affiliateUrl  String?

  isActive      Boolean  @default(true)

  rawPayload    Json?

  createdAt     DateTime @default(now())
  taxonomyGroup      String?
  taxonomySubgroup   String?
  taxonomySource     String?
  taxonomyEnrichedAt DateTime?
  styleTags          String[] @default([])
  occasionTags       String[] @default([])
  seasonTags         String[] @default([])
  colorFamily        String?

  updatedAt     DateTime @updatedAt

  @@unique([merchant, externalId])
  aiReviews CatalogProductAIReview[]
}



model CatalogProductAIReview {
  id                         String   @id @default(cuid())
  productId                  String
  merchant                   String
  model                      String
  status                     String   @default("REVIEWED")

  isTryOnRelevantSuggested   Boolean?
  taxonomyGroupSuggested     String?
  taxonomySubgroupSuggested  String?
  genderSuggested            String?
  colorFamilySuggested       String?
  seasonTagsSuggested        String[]
  occasionTagsSuggested      String[]
  styleTagsSuggested         String[]
  rejectReasons              String[]
  confidence                 Float?
  explanation                String?

  inputHash                  String
  rawInput                   Json?
  rawOutput                  Json?
  error                      String?

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  appliedAt                  DateTime?

  product                    CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([merchant])
  @@index([status])
  @@index([inputHash])
}

model CatalogPipelineRun {
  id          String   @id
  kind        String   @default("nightly-catalog")
  status      String   @default("RUNNING")
  applySafe   Boolean  @default(false)
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  reportText  String?
  reportPath  String?
  meta        Json?
  error       String?

  steps CatalogPipelineStep[]

  @@index([kind])
  @@index([status])
  @@index([startedAt])
}

model CatalogPipelineStep {
  id         String   @id @default(cuid())
  runId      String
  name       String
  merchant   String?
  status     String   @default("RUNNING")
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  durationMs Int?
  result     Json?
  error      String?

  run CatalogPipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([name])
  @@index([merchant])
  @@index([status])
}

model CatalogProductPriceSnapshot {
  productId   String   @id
  merchant    String
  title       String?
  price       Float?
  oldPrice    Float?
  currency    String?
  imageUrl    String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([merchant])
  @@index([lastSeenAt])
}

model CatalogProductPriceChange {
  id            String   @id
  changeKey     String   @unique
  productId     String
  merchant      String
  title         String?
  previousPrice Float
  currentPrice  Float
  delta         Float
  deltaPct      Float
  direction     String
  detectedAt    DateTime @default(now())
  pipelineRunId String?
  imageUrl       String?
  productUrl     String?
  affiliateUrl   String?

  @@index([merchant])
  @@index([productId])
  @@index([detectedAt])
  @@index([direction])
}

model UserEntitlement {
  id                String   @id
  userId            String   @unique
  plan              String   @default("FREE")
  isAdmin           Boolean  @default(false)
  dailyLookLimit    Int      @default(3)
  monthlyLookLimit  Int      @default(20)
  meta              Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([isAdmin])
}

model UsageEvent {
  id          String   @id
  userId      String
  type        String
  status      String
  lookId      String?
  qualityMode String?
  itemCount   Int?
  durationMs  Int?
  error       String?
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type, status, createdAt])
  @@index([lookId])
  @@index([type])
  @@index([status])
}

model GenerationCreditGrant {
  id        String    @id
  userId    String
  amount    Int
  remaining Int
  reason    String
  expiresAt DateTime?
  meta      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, remaining])
  @@index([userId, reason])
  @@index([reason])
  @@index([expiresAt])
}

model ReferralCode {
  id        String   @id
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model ReferralReward {
  id                   String   @id
  inviterUserId         String
  invitedUserId         String   @unique
  referralCode          String
  status                String   @default("REWARDED")
  inviterCreditGrantId  String?
  invitedCreditGrantId  String?
  meta                  Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([inviterUserId])
  @@index([referralCode])
  @@index([status])
}

